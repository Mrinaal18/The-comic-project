# =============================================================================
# Inkverse — Streamlit secrets template
# -----------------------------------------------------------------------------
# 1. Copy this file to ".streamlit/secrets.toml" for LOCAL development, OR
# 2. Paste these values into the "Secrets" box in Streamlit Community Cloud
#    (App -> Settings -> Secrets) for deployment.
#
# The app runs WITHOUT these (it falls back to a local JSON store and disables
# AI), but for real persistence + the copyright checker you should set them.
# =============================================================================

# ---- GitHub-backed storage --------------------------------------------------
# A GitHub Personal Access Token with "repo" (contents read/write) scope.
# Create one at: https://github.com/settings/tokens
github_token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The repository used as the database, in "owner/name" form.
# It can be the SAME repo you deploy from, or a separate private data repo.
github_repo = "your-username/inkverse-data"

# Branch to read/write data on (defaults to "main" if omitted).
github_branch = "main"

# Folder inside the repo where JSON data files are stored.
github_data_path = "data"

# ---- AI copyright checker (OpenAI) ------------------------------------------
# API key from https://platform.openai.com/api-keys
openai_api_key = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional model overrides
openai_chat_model = "gpt-4o-mini"
openai_embedding_model = "text-embedding-3-small"

# ---- App settings -----------------------------------------------------------
# Optional: a long random string used to salt session tokens.
app_secret = "change-me-to-a-long-random-string"
